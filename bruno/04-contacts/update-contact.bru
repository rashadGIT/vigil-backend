meta {
  name: Update Contact
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/cases/{{caseId}}/contacts/{{contactId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "phone": "555-0199",
    "isPrimaryContact": true
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
