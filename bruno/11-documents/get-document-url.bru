meta {
  name: Get Document URL
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/documents/{{documentId}}/url
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("has url", function() {
    expect(res.getBody()).to.have.property("url");
  });
}
