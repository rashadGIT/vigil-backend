meta {
  name: Grant Family Portal Access
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/cases/{{caseId}}/family-portal/grant
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "contactId": "{{contactId}}"
  }
}

script:post-response {
  const data = res.getBody();
  if (data.accessToken) {
    bru.setEnvVar("familyPortalToken", data.accessToken);
  }
}

tests {
  test("status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
