meta {
  name: Update Death Certificate
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/cases/{{caseId}}/death-certificate
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "status": "physician_signed",
    "physicianSignedAt": "2024-01-13T16:00:00.000Z",
    "certifiedCopiesReceived": 5
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
