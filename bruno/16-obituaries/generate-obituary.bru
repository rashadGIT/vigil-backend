meta {
  name: Generate Obituary
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/cases/{{caseId}}/obituary/generate
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200 or 201", function() {
    expect([200, 201]).to.include(res.getStatus());
  });
}
