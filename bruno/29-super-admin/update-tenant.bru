meta {
  name: Update Tenant (Super Admin)
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/super-admin/tenants/{{tenantId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "planTier": "growth",
    "active": true
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
