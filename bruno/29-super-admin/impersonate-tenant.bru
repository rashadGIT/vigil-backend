meta {
  name: Impersonate Tenant (Super Admin)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/super-admin/impersonate/{{tenantId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200 or 201", function() {
    expect([200, 201]).to.include(res.getStatus());
  });
}
