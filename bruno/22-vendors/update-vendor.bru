meta {
  name: Update Vendor
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/vendors/{{vendorId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "phone": "555-0399",
    "contactName": "Mary Jane Williams"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
