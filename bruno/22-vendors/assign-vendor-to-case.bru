meta {
  name: Assign Vendor to Case
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/cases/{{caseId}}/vendors
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "vendorId": "{{vendorId}}",
    "role": "florist"
  }
}

tests {
  test("status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
