meta {
  name: Generate Service Program (Internal)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/internal/documents/generate-service-program/{{caseId}}
  body: json
  auth: none
}

headers {
  x-internal-secret: {{internalSecret}}
}

body:json {
  {
    "tenantId": "{{tenantId}}"
  }
}

tests {
  test("status is 200 or 201", function() {
    expect([200, 201]).to.include(res.getStatus());
  });
}
