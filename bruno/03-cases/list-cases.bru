meta {
  name: List Cases
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/cases
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

params:query {
  ~status: new
  ~dashboardFilter: active
  ~assignedToId:
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("returns array", function() {
    expect(res.getBody()).to.be.an("array");
  });
}
