meta {
  name: Schedule Follow-up
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/cases/{{caseId}}/follow-ups
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "contactId": "{{contactId}}"
  }
}

tests {
  test("status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
