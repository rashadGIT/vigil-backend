meta {
  name: Update Calendar Event
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/calendar/events/{{eventId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "title": "Visitation — John Doe (Updated)",
    "eventType": "visitation",
    "startTime": "2024-01-18T14:00:00.000Z",
    "endTime": "2024-01-18T18:00:00.000Z"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
