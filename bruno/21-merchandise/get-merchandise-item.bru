meta {
  name: Get Merchandise Item
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/merchandise/{{merchandiseId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("has id", function() {
    expect(res.getBody()).to.have.property("id");
  });
}
