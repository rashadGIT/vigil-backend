#!/usr/bin/env sh

# Mirrors GitHub Actions (ci.yml + security.yml) locally.
# Skips: E2E/Playwright (requires full stack).

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo ""
echo "▶  Pre-push checks (mirroring GitHub Actions)..."
echo ""

# ── 1. Type check ──────────────────────────────────────────────────────────
echo "→ [1/6] TypeScript type check..."
npm run type-check --workspaces --if-present
echo "✓ Type check passed"
echo ""

# ── 2. Lint ────────────────────────────────────────────────────────────────
echo "→ [2/6] ESLint..."
npm run lint --workspaces --if-present
echo "✓ Lint passed"
echo ""

# ── 3. Build ───────────────────────────────────────────────────────────────
echo "→ [3/6] Build..."
npm run build --workspaces --if-present
echo "✓ Build passed"
echo ""

# ── 4. Backend tests ───────────────────────────────────────────────────────
echo "→ [4/6] Backend tests (unit + contract)..."
if nc -z localhost 5432 2>/dev/null; then
  cd "$ROOT/backend"
  npx prisma generate --quiet
  npm run test:coverage
  cd "$ROOT"
  echo "✓ Backend tests passed"
else
  echo "⚠  Postgres not reachable on :5432 — skipping backend tests"
  echo "   Run 'docker-compose up -d' to enable this check"
fi
echo ""

# ── 5. Frontend tests ──────────────────────────────────────────────────────
echo "→ [5/6] Frontend tests (unit + component)..."
cd "$ROOT/frontend"
npm run test -- --passWithNoTests
cd "$ROOT"
echo "✓ Frontend tests passed"
echo ""

# ── 6. Security ────────────────────────────────────────────────────────────
echo "→ [6/6] Security checks..."

echo "   npm audit (high severity)..."
npm audit --audit-level=high

if command -v trufflehog >/dev/null 2>&1; then
  echo "   TruffleHog secret scan..."
  trufflehog git file://. --since-commit HEAD~1 --only-verified --fail
  echo "✓ No verified secrets found"
else
  echo "   ⚠  TruffleHog not installed — skipping secret scan"
  echo "      Install: brew install trufflehog"
fi

echo "✓ Security passed"
echo ""

echo "✅ All pre-push checks passed — pushing."
echo ""
