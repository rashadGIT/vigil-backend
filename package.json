{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:contract": "jest --config jest.contract.config.ts",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "build:lambda": "nest build && npm prune --omit=dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,js}": "eslint --fix",
    "**/*.{ts,js,json,md}": "prettier --write"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "3.1047.0",
    "@aws-sdk/client-s3": "3.1047.0",
    "@aws-sdk/client-secrets-manager": "^3.1045.0",
    "@aws-sdk/client-ses": "3.1047.0",
    "@aws-sdk/client-sns": "3.1047.0",
    "@aws-sdk/s3-request-presigner": "3.1047.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "11.1.21",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.21",
    "@nestjs/platform-express": "11.1.21",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.3",
    "@nestjs/throttler": "6.5.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nestjs": "^10.52.0",
    "@sentry/node": "^10.52.0",
    "aws-jwt-verify": "5.1.1",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "8.1.0",
    "pdfkit": "0.18.0",
    "reflect-metadata": "^0.2.2",
    "resend": "6.10.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "11.1.21",
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "0.17.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^13.24.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  }
}
