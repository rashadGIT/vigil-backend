# ============================================================
# Kelova Backend — Environment Variables
# Copy this file to .env and populate values for your environment.
# NEVER commit .env — only .env.example is safe to commit.
# ============================================================

# ------------------------------------
# Application
# ------------------------------------
NODE_ENV=development
PORT=3001
APP_DOMAIN=localhost

# ------------------------------------
# Database (Docker Compose local: docker-compose up -d)
# ------------------------------------
DATABASE_URL=postgresql://vigil:vigil@localhost:5432/vigil_dev

# ------------------------------------
# Redis (Docker Compose local: docker-compose up -d)
# ------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------
# AWS Cognito — Auth (Cognito only; no custom JWT)
# Values available after Phase 8 CDK deploy (AuthStack outputs)
# ------------------------------------
COGNITO_USER_POOL_ID=us-east-2_REPLACE_AFTER_CDK_DEPLOY
COGNITO_CLIENT_ID=REPLACE_AFTER_CDK_DEPLOY
COGNITO_REGION=us-east-2

# ------------------------------------
# AWS General
# ------------------------------------
AWS_REGION=us-east-2

# ------------------------------------
# AWS S3 — Document + Asset Storage
# Bucket names available after Phase 8 CDK deploy (DataStack outputs)
# ------------------------------------
AWS_S3_DOCUMENTS_BUCKET=vigil-documents-local
AWS_S3_ASSETS_BUCKET=vigil-assets-local

# ------------------------------------
# Email Provider Strategy
# Local dev / pre-SES: EMAIL_PROVIDER=resend + RESEND_API_KEY (free tier, no domain verification needed)
# Production: EMAIL_PROVIDER=ses (requires SES domain verification + sandbox exit)
# n8n grief follow-up workflows always use SES directly (configured inside n8n AWS SES node)
# ------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SES_FROM_ADDRESS=dev@kelovaapp.com

# ------------------------------------
# Local Dev Auth Bypass
# Set DEV_AUTH_BYPASS=true locally to skip Cognito and inject mock user via x-dev-user header.
# NEVER set to true in production.
# ------------------------------------
DEV_AUTH_BYPASS=false

# ------------------------------------
# n8n Automation Webhooks (Phase 9)
# All URLs are placeholders until Wave 9 creates the workflows in rashadbarnett.app.n8n.cloud.
# N8nService logs a WARNING (not error) when a URL is still a placeholder — app will not crash.
# After Wave 9: copy real webhook URLs here AND into AWS Secrets Manager.
# ------------------------------------
N8N_WEBHOOK_GRIEF_FOLLOWUP=https://rashadbarnett.app.n8n.cloud/webhook/grief-followup
N8N_WEBHOOK_STAFF_NOTIFY=https://rashadbarnett.app.n8n.cloud/webhook/staff-notify
N8N_WEBHOOK_INTAKE_NOTIFY=https://rashadbarnett.app.n8n.cloud/webhook/intake-notify
N8N_WEBHOOK_DOC_GENERATE=https://rashadbarnett.app.n8n.cloud/webhook/doc-generate
N8N_WEBHOOK_REVIEW_REQUEST=https://rashadbarnett.app.n8n.cloud/webhook/review-request
N8N_WEBHOOK_KEY=local_dev_key_replace_in_prod

# ------------------------------------
# Internal API (used by @InternalOnly() guard for n8n → backend callbacks)
# ------------------------------------
INTERNAL_API_KEY=local_internal_key_replace_in_prod

# ------------------------------------
# Sentry (Observability — Phase 8 CDK ObservabilityStack)
# Leave blank until Sentry DSN is provisioned in Phase 8.
# ------------------------------------
SENTRY_DSN=

# ------------------------------------
# Test database (docker-compose.test.yml — postgres:16 on port 5433)
# Required for the tenant isolation integration test only.
# Run: TEST_DATABASE_URL=... npx jest test/tenant-isolation.e2e-spec.ts --no-coverage
# ------------------------------------
TEST_DATABASE_URL=postgresql://vigil:vigil@localhost:5433/vigil_test
